<Window x:Class="eartq.ModernMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mesaj" Height="200" Width="400" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">
    <Border Background="#252526" BorderBrush="#007ACC" BorderThickness="2" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            
            <Border Background="#1E1E1E" CornerRadius="10,10,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock x:Name="TxtTitle" Text="Bilgi" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
            </Border>

            <TextBlock x:Name="TxtMessage" Grid.Row="1" Text="Message Here" Foreground="#D4D4D4" TextWrapping="Wrap" Margin="20" VerticalAlignment="Center" FontSize="14"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="BtnOk" Content="Tamam" Width="100" Height="30" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnOk_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
