<Window x:Class="eartq.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acil Durum Widget" Height="100" Width="100"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        Topmost="True" WindowStartupLocation="Manual" Left="{Binding SystemParameters.WorkArea.Right, FallbackValue=800}" Top="50">
    
    <Border x:Name="WidgetBorder" 
            Background="#AA000000" 
            BorderBrush="Red" BorderThickness="3" 
            CornerRadius="50" 
            MouseLeftButtonDown="WidgetBorder_MouseLeftButtonDown">
        
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Ayarlar" Click="MenuSettings_Click" />
                <MenuItem Header="Çıkış" Click="MenuExit_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        
        <Button x:Name="BtnRecord" 
                Background="Transparent" BorderThickness="0" 
                Click="BtnRecord_Click" Cursor="Hand"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <Ellipse x:Name="RecordIndicator" Width="50" Height="50" Fill="Red" Stroke="White" StrokeThickness="3">
                <Ellipse.Effect>
                    <DropShadowEffect Color="Red" BlurRadius="20" ShadowDepth="0" />
                </Ellipse.Effect>
            </Ellipse>
        </Button>
    </Border>
</Window>
